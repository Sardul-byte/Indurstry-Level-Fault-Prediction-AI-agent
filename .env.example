# ── LLM Provider ────────────────────────────────────────────────────────────
# Which LLM provider to use: gemini | openai | anthropic
LLM_PROVIDER=gemini
# Model name for the selected provider
LLM_MODEL=gemini-2.0-flash

# ── LLM API Keys ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Qdrant Vector Store ───────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=knowledge_base

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/incident_commander
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=incident_commander

# ── LangSmith Observability ───────────────────────────────────────────────────
LANGSMITH_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=ai-incident-response-commander

# ── MCP Tool Settings ─────────────────────────────────────────────────────────
# Timeout (seconds) for each MCP tool call
MCP_TIMEOUT_SECONDS=10
# Maximum characters to accept from a single MCP tool response
MCP_RESPONSE_CAP=50000

# ── RAG Retrieval Settings ────────────────────────────────────────────────────
# Number of top documents to retrieve (1–20)
RAG_K=5
# Minimum cosine similarity score to include a result (0.0–1.0)
RAG_SIMILARITY_THRESHOLD=0.5

# ── API Server ────────────────────────────────────────────────────────────────
# Port the API service is exposed on (used by docker-compose)
API_PORT=8000
# Maximum accepted request body size in megabytes
MAX_PAYLOAD_SIZE_MB=50
